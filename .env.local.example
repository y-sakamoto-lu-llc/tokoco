# ============================================================
# Tokoco — ローカル開発用環境変数テンプレート
#
# 使い方:
#   cp .env.local.example .env.local
#   .env.local に実際の値を入力して保存する
#
# .env.local は .gitignore に含まれているためコミットされません。
# 本番・ステージング環境の値は GitHub Actions Secrets および
# Cloudflare Pages の環境変数として別途設定してください。
# ============================================================

# ------------------------------------------------------------
# Supabase（ローカル開発）
#
# `supabase start` 実行後に表示される値を使用してください。
# 本番値は GitHub Actions Secrets / Cloudflare Pages 環境変数に設定:
#   - NEXT_PUBLIC_SUPABASE_URL
#   - NEXT_PUBLIC_SUPABASE_ANON_KEY
# ------------------------------------------------------------

# ローカル Supabase API URL（`supabase start` で表示される "API URL"）
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# ローカル Supabase anon key（`supabase start` で表示される "anon key"）
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ------------------------------------------------------------
# Supabase サービスロールキー（サーバーサイド専用）
#
# NEXT_PUBLIC_ プレフィックスを絶対につけないこと。
# このキーは Route Handler 内からのみ使用する。
# クライアントバンドルに含めてはならない。
#
# 本番値は GitHub Actions Secrets / Cloudflare Pages 環境変数に設定:
#   - SUPABASE_SERVICE_ROLE_KEY
# ------------------------------------------------------------

# ローカル Supabase service_role key（`supabase start` で表示される "service_role key"）
SUPABASE_SERVICE_ROLE_KEY=

# ------------------------------------------------------------
# Drizzle ORM データベース接続URL
#
# 本番値は GitHub Actions Secrets / Cloudflare Pages 環境変数に設定:
#   - DATABASE_URL
# ------------------------------------------------------------

# ローカル DB 接続URL（`supabase start` で表示される "DB URL"）
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ------------------------------------------------------------
# アプリケーション設定
#
# 本番値は Cloudflare Pages 環境変数に設定:
#   - NEXT_PUBLIC_SITE_URL（例: https://tokoco.pages.dev）
# ------------------------------------------------------------

# サイトURL（ゲスト共有リンク生成・OAuth コールバックURLに使用）
# ローカル開発時は http://localhost:3000 を使用
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ------------------------------------------------------------
# Google Places API キー（サーバーサイド専用）
#
# NEXT_PUBLIC_ プレフィックスを絶対につけないこと。
# このキーは Route Handler 内からのみ使用する。
# クライアントバンドルに含めてはならない。
#
# 取得方法: https://console.cloud.google.com/
#   Places API（New）を有効化してAPIキーを発行
#
# 本番値は GitHub Actions Secrets / Cloudflare Pages 環境変数に設定:
#   - GOOGLE_PLACES_API_KEY
# ------------------------------------------------------------

GOOGLE_PLACES_API_KEY=
