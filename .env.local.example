# Supabase ローカル開発環境の接続情報
# `supabase start` 実行後に表示される値をコピーしてください
# このファイルをコピーして .env.local を作成してください: cp .env.local.example .env.local

# ローカル Supabase API URL（`supabase start` で起動後に表示される "API URL"）
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# ローカル Supabase anon key（`supabase start` で起動後に表示される "anon key"）
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ローカル Supabase service role key（サーバーサイドのみ使用。クライアントバンドルに含めないこと）
# `supabase start` で起動後に表示される "service_role key"
SUPABASE_SERVICE_ROLE_KEY=

# ローカル Supabase DB 接続URL（Drizzle ORM マイグレーション用）
# `supabase start` で起動後に表示される "DB URL"
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
